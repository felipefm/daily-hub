# Ignorar bancos de dados (MUITO IMPORTANTE)
*.sqlite
*.sqlite3
*.db
/data/
/db/

# Ignorar arquivos temporários do Python
__pycache__/
*.pyc
*.py[cod]
*$py.class

# Ignorar ambientes virtuais (se tiver)
venv/
env/

# Ignorar arquivos de variáveis de ambiente com senhas (se você criar um no futuro)
.env

# Logs gerados pelos testes
app/tests/logs/
*.log

# Cache do Pytest (arquivos temporários)
.pytest_cache/

# Pasta da documentação gerada do testes
/docs/